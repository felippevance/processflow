<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>ProcessFlow User</label>
    <description>Run ProcessFlow processes. Read-only on Process/Stage/Step. Full CRUD on own Executions. Access to Runner LWC and Process Flow app.</description>

    <!-- Apex Class Access -->
    <classAccesses>
        <apexClass>ProcessRunnerController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ProcessExecutionEngine</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ProcessViewerController</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- Tab Visibility: Process only visible to user -->
    <tabSettings>
        <tab>Process__c</tab>
        <visibility>Available</visibility>
    </tabSettings>

    <!-- Object: Process__c (read only) -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Process__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Object: Stage__c (read only) -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Stage__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Object: Step__c (read only) -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Step__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>

    <!-- Object: Execution__c (full CRUD own records only) -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Execution__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- Field Access: Process__c (read only) -->
    <fieldPermissions>
        <editable>false</editable>
        <field>Process__c.Description__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Process__c.IsActive__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Process__c.Version__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Process__c.IsCurrentVersion__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Field Access: Stage__c (read only) -->
    <fieldPermissions>
        <editable>false</editable>
        <field>Stage__c.Sequence__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Field Access: Step__c (read only) -->
    <fieldPermissions>
        <editable>false</editable>
        <field>Step__c.Sequence__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Step__c.Type__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Step__c.TargetObject__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Step__c.FieldsConfig__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Step__c.IsRequired__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- Field Access: Execution__c (full) -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Execution__c.Process__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Execution__c.User__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Execution__c.StartedAt__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Execution__c.Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Execution__c.CurrentStage__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Execution__c.CurrentStep__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Execution__c.ExecutionData__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <hasActivationRequired>false</hasActivationRequired>
    <license>Salesforce</license>
</PermissionSet>
